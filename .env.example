# Copy this file to .env and fill in your values before running docker compose.
# Never commit .env to version control.

SPRING_PROFILES_ACTIVE=local

DB_USERNAME=urlshortener
DB_PASSWORD=urlshortener

REDIS_PASSWORD=

# Base64-encoded HMAC-SHA256 key, minimum 32 bytes.
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-generate-a-real-secret-before-use

GF_SECURITY_ADMIN_PASSWORD=admin
