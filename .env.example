# Copy this file to .env and fill in your values before running docker compose.
# Never commit .env to version control.

SPRING_PROFILES_ACTIVE=local

DB_USERNAME=urlshortener
DB_PASSWORD=urlshortener

REDIS_PASSWORD=

# Base64-encoded HMAC-SHA256 key, minimum 32 bytes decoded.
# THIS VALUE IS FOR LOCAL DEVELOPMENT ONLY. Replace before any deployment.
# Generate a production secret with: openssl rand -base64 32
JWT_SECRET=bG9jYWwtZGV2LW9ubHktY2hhbmdlLWluLXByb2R1Y3Q=

GF_SECURITY_ADMIN_PASSWORD=admin

# Jaeger host ports — override if another local project occupies the defaults.
# Defaults avoid conflict with VaultFlow (which uses 16686, 4317, 4318).
JAEGER_UI_PORT=16687
JAEGER_OTLP_HTTP_PORT=4418
JAEGER_OTLP_GRPC_PORT=4417
