{
  "title": "URL Shortener - Platform Overview",
  "uid": "url-shortener-overview",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["url-shortener", "platform"],
  "panels": [
    {
      "id": 1,
      "title": "Redirect Rate (req/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{
        "expr": "rate(url_redirect_duration_seconds_count[1m])",
        "legendFormat": "redirects/sec"
      }],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "Redirect P99 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(url_redirect_duration_seconds_bucket{cache='hit'}[5m]))",
          "legendFormat": "p99 cache hit"
        },
        {
          "expr": "histogram_quantile(0.99, rate(url_redirect_duration_seconds_bucket{cache='miss'}[5m]))",
          "legendFormat": "p99 cache miss"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "red", "value": 0.05 }
          ]
        }}
      }
    },
    {
      "id": 3,
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "targets": [{
        "expr": "rate(cache_hit_total{cache='redis'}[5m]) / (rate(cache_hit_total{cache='redis'}[5m]) + rate(cache_miss_total{cache='redis'}[5m]))",
        "legendFormat": "Hit ratio"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "URLs Created (last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [{
        "expr": "increase(url_created_total[1h])",
        "legendFormat": "URLs created"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 5,
      "title": "Rate Limit Violations",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [{
        "expr": "increase(rate_limit_exceeded_total[5m])",
        "legendFormat": "violations"
      }],
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "red", "value": 100 }
          ]
        }}
      }
    },
    {
      "id": 6,
      "title": "HTTP Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [{
        "expr": "rate(http_server_requests_seconds_count{status=~'5..'}[5m])",
        "legendFormat": "5xx errors/sec"
      }],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "fixedColor": "red", "mode": "fixed" } }
      }
    },
    {
      "id": 7,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "kafka_consumer_fetch_manager_records_lag{topic='url.click-events'}",
          "legendFormat": "click-events lag"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1000 },
            { "color": "red", "value": 10000 }
          ]
        }}
      }
    },
    {
      "id": 8,
      "title": "JVM Heap Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area='heap'}",
          "legendFormat": "heap used"
        },
        {
          "expr": "jvm_memory_max_bytes{area='heap'}",
          "legendFormat": "heap max"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 9,
      "title": "DB Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "hikaricp_connections_active",
          "legendFormat": "active"
        },
        {
          "expr": "hikaricp_connections_pending",
          "legendFormat": "pending"
        },
        {
          "expr": "hikaricp_connections_max",
          "legendFormat": "max"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}
